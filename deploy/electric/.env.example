# Direct (non-pooled) Neon PostgreSQL URL for logical replication.
# Get this from Neon Console → Connect → Turn OFF "Pooled connection".
# Remove channel_binding=require from the URL.
# Example: postgresql://neondb_owner:xxx@ep-restless-frog-amxe2l98.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require
ELECTRIC_DATABASE_URL=

# Secret for authenticating shape proxy requests.
# Generate with: openssl rand -hex 32
ELECTRIC_SECRET=

# Log level: error | warning | info | debug
ELECTRIC_LOG_LEVEL=info
