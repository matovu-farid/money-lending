# PostgreSQL connection URL for Electric's logical replication tap.
# After migration this points at the local postgres service over the docker
# overlay network. Before migration it was Neon's direct (non-pooled) URL.
# Example (post-migration): postgres://money:PG_PASSWORD@postgres:5432/money_lending?sslmode=require
ELECTRIC_DATABASE_URL=

# Secret for authenticating shape proxy requests.
# Generate with: openssl rand -hex 32
ELECTRIC_SECRET=

# Password for the `money` postgres role in the self-hosted DB.
# Used by the postgres service to initialize the DB and by ELECTRIC_DATABASE_URL
# above. Vercel's DATABASE_URL must use the same password.
# Generate with: openssl rand -base64 32 | tr -d '/+='
PG_PASSWORD=

# Log level: error | warning | info | debug
ELECTRIC_LOG_LEVEL=info
