{
  "name": "money-lending",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:test:setup": "npx tsx scripts/setup-test-db.ts",
    "test:e2e": "CYPRESS=true DATABASE_URL=$DATABASE_URL_TEST next dev -p 3001 & sleep 5 && cypress run; kill %1 2>/dev/null",
    "test:e2e:open": "CYPRESS=true DATABASE_URL=$DATABASE_URL_TEST next dev -p 3001 & cypress open; kill %1 2>/dev/null",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@tanstack/react-query": "^5.94.5",
    "better-auth": "^1.5.5",
    "bignumber.js": "^10.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "effect": "^3.21.0",
    "exceljs": "^4.4.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.577.0",
    "next": "16.2.0",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "postgres": "^3.4.8",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "resend": "^6.9.4",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.1",
    "@electric-sql/pglite-socket": "^0.1.1",
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-query-devtools": "^5.94.5",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dotenv": "^8.2.3",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "1.0.0",
    "cypress": "^15.12.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "executionEnv": {
      "nodeVersion": "22.16.0"
    },
    "onlyBuiltDependencies": [
      "cypress",
      "msw"
    ]
  }
}
