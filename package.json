{
  "name": "money-lending",
  "version": "1.3.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:stack": "NGINX_CONF_HASH=dev docker compose --project-directory . -f deploy/electric/docker-stack.yml -f docker-compose.dev.yml up -d",
    "dev:stack:down": "NGINX_CONF_HASH=dev docker compose --project-directory . -f deploy/electric/docker-stack.yml -f docker-compose.dev.yml down",
    "dev:stack:logs": "NGINX_CONF_HASH=dev docker compose --project-directory . -f deploy/electric/docker-stack.yml -f docker-compose.dev.yml logs -f",
    "build": "next build",
    "postbuild": "drizzle-kit migrate && tsx scripts/db-verify-triggers.ts",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "test:all": "vitest run && cypress run",
    "typecheck": "tsc --noEmit",
    "validate": "tsc --noEmit && vitest run && cypress run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:mark-applied": "tsx scripts/db-mark-migrations-applied.ts",
    "db:verify-triggers": "tsx scripts/db-verify-triggers.ts",
    "db:backfill-allocations": "tsx scripts/db-backfill-payment-allocations.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run"
  },
