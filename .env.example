DATABASE_URL=postgresql://user:password@localhost:5432/money_lending
BETTER_AUTH_SECRET=your-secret-key-here-min-32-chars
BETTER_AUTH_URL=http://localhost:3000
BUSINESS_TIMEZONE=Africa/Kampala
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=Lending Manager <noreply@yourdomain.com>
CRON_SECRET=your-cron-secret-here

# ElectricSQL sync engine
# URL where the Electric server is running (the Next.js proxy route connects to this)
ELECTRIC_URL=http://localhost:3001
# Secret for authenticating shape proxy requests (must match Electric server config)
ELECTRIC_SECRET=

# Sentry error monitoring
# The SDK is only active when NODE_ENV === "production" AND a DSN is set, so
# these are safe to leave blank locally.
#
# Public DSN (browser + server). Must be the same value; the NEXT_PUBLIC_
# prefix exposes it to the client bundle.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
#
# Build-time only — used by withSentryConfig for source-map upload. Generate
# an "Internal Integration" token with `project:releases` + `org:read` scope
# at https://sentry.io/orgredirect/organizations/:orgslug/settings/auth-tokens/
# and store it in the Vercel project settings → Environment Variables.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=farid-org
SENTRY_PROJECT=money-lending
